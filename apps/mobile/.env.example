# Copy this file to apps/mobile/.env for local Expo development.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.
# Do not put service role keys, Resend keys, or generation secrets here.

# Supabase Project URL, for example:
# EXPO_PUBLIC_SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public API key from Project Settings > API.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: during live proof runs, mock fallback logs are emitted as console errors.
EXPO_PUBLIC_LIVE_DATA_PROOF_MODE=false
