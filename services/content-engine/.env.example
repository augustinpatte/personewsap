# Copy to services/content-engine/.env for local content-engine commands.
# This file is server-side only. Never copy SUPABASE_SERVICE_ROLE_KEY into
# apps/mobile/.env, Vite env files, Expo public env vars, or client code.

# Required for read-only diagnostics and any persistence/write test command.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Required only when intentionally running npm run content:daily-job-test:local.
# Keep false until you are ready to write marked test content/daily drops.
CONFIRM_DAILY_JOB_TEST=false

# Safe local defaults for daily-job-test/debug-users.
LANGUAGES=en
USER_LIMIT=3
CONTENT_STATUS=published
USE_LLM=false
LIVE_RSS=false
LIVE_RSS_ONLY=false
RSS_ARTICLES_PER_SOURCE=1

# Optional LLM/live-source settings. Do not set OPENAI_API_KEY unless USE_LLM=true.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_MODEL=
OPENAI_REQUEST_TIMEOUT_MS=120000
